<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="40dp">

    <!-- Glow circle behind icon -->
    <FrameLayout
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_gravity="center_horizontal">

        <View
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:background="@drawable/glow_circle"
            android:layout_gravity="center" />

        <ImageView
            android:id="@+id/ivSplashLogo"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_lock_image"
            android:tint="@color/accent_cyan" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvSplashTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="StegoVault"
        android:textColor="@color/text_primary"
        android:textSize="32sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-condensed"
        android:alpha="0" />

    <TextView
        android:id="@+id/tvSplashSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Image Steganography System"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:letterSpacing="0.2"
        android:alpha="0" />

    <View
        android:layout_width="60dp"
        android:layout_height="2dp"
        android:layout_marginTop="20dp"
        android:background="@color/accent_cyan"
        android:alpha="0" />

</LinearLayout>
